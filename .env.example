ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

HA_URL=http://localhost:8123
HA_TOKEN=eyJ...
HA_VACUUM_ENTITY=vacuum.eufy_tj_home

# iMessage destinations.
# Phone in +E.164 format ("+15551234567") or Apple ID email.
# Leave blank to disable; the system will just log instead.
#   HUSBAND_IMESSAGE_HANDLE -- where the bedroom-clutter alert goes
#   USER_IMESSAGE_HANDLE    -- where the stuck-watcher alert goes (you)
HUSBAND_IMESSAGE_HANDLE=
USER_IMESSAGE_HANDLE=

# Shared secret for the /greet endpoint (used by iPhone's "When I Arrive Home"
# automation). Generate any random string. The iPhone Shortcut sends it as
# "Authorization: Bearer <token>". Leave blank to disable the endpoint.
GREET_TOKEN=

# Welcome-dance navigation. The room name must match what you labeled in
# the Eufy Clean app's map (case-insensitive). If unset or not in your map,
# the robot dances in place instead.
ENTRYWAY_ROOM_NAME=Entryway

# Seconds to wait for the robot to drive from its current spot to the
# entryway before we pause it and start the dance. Tune by timing your
# actual robot: watch the longest path (e.g., dock -> door) and set the
# delay to that + a few seconds buffer.
WELCOME_TRAVEL_DELAY_SECONDS=60

# How many seconds before the robot starts dancing should the music kick in.
# Defaults to 5 -- music is audible just before the dance begins.
MUSIC_LEAD_SECONDS=5

# Spotify Web API (for music-on-Echo during the welcome dance).
# Get from https://developer.spotify.com/dashboard after creating an app.
# Add redirect URI http://localhost:8888/callback to your Spotify app.
# Then run once:  python -m eufy_llm.spotify_auth
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Name of your Echo as it appears in Spotify Connect (look at the device
# picker in the Spotify app). Often something like "Tram's Echo" or "Kitchen Echo".
ECHO_DEVICE_NAME=
